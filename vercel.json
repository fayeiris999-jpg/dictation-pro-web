{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/teacher",
      "dest": "/teacher-v4.html"
    },
    {
      "src": "/student",
      "dest": "/student-v4.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
